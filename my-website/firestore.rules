rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return signedIn() && (
        request.auth.uid == "6t6m25YN7AM2d8iIecT6kUTC1me2"
        || (
          request.auth.token.email != null
          && request.auth.token.email == "emviemsalva@gmail.com"
        )
      );
    }

    function adminDocExists() {
      return signedIn() && exists(
        /databases/$(database)/documents/cineflexAdmins/$(request.auth.uid)
      );
    }

    function adminDoc() {
      return get(
        /databases/$(database)/documents/cineflexAdmins/$(request.auth.uid)
      );
    }

    function hasAdminRole(roles) {
      return signedIn() && (
        isOwner()
        || (
          adminDocExists()
          && adminDoc().data.active == true
          && adminDoc().data.role in roles
        )
      );
    }

    function isAdmin() {
      return hasAdminRole([
        "super_admin",
        "moderator",
        "support",
        "content_manager"
      ]);
    }

    match /users/{uid}/profiles/{profileId} {
      allow read, create, update, delete:
        if signedIn() && request.auth.uid == uid;
    }

    match /users/{uid}/membership/{documentId} {
      allow read:
        if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create, update, delete: if isOwner();
    }

    match /vipRequests/{requestId} {
      allow create:
        if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow read:
        if signedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /users/{uid}/watchProgress/{progressId} {
      allow read, create, update, delete:
        if signedIn() && request.auth.uid == uid;
    }

    match /users/{uid}/watchTime/{document=**} {
      allow read:
        if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /livePresence/{sessionId} {
      allow read: if true;
      allow create, update:
        if request.resource.data.lastSeenMs is int
        && request.resource.data.mediaKey is string;
      allow delete: if signedIn();
    }

    match /cineflex_reactions/{titleKey} {
      allow read: if true;
      allow create, update: if signedIn();
      allow delete: if false;

      match /users/{uid} {
        allow read: if signedIn();
        allow create, update, delete:
          if signedIn() && request.auth.uid == uid;
      }
    }

    match /cineflex_activity/{activityId} {
      allow read: if true;
      allow create:
        if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete:
        if signedIn()
        && resource.data.uid == request.auth.uid;
    }

    match /cineflexAdmins/{uid} {
      allow read:
        if signedIn()
        && (isOwner() || request.auth.uid == uid);
      allow create, update, delete: if isOwner();
    }

    match /userModeration/{uid} {
      allow read:
        if signedIn()
        && (
          request.auth.uid == uid
          || hasAdminRole(["super_admin", "moderator", "support"])
        );
      allow create, update:
        if hasAdminRole(["super_admin", "moderator", "support"]);
      allow delete:
        if hasAdminRole(["super_admin", "moderator"]);
    }

    match /adminAuditLogs/{id} {
      allow read:
        if hasAdminRole(["super_admin", "moderator", "support"]);
      allow create:
        if hasAdminRole([
          "super_admin",
          "moderator",
          "support",
          "content_manager"
        ]);
      allow update, delete: if false;
    }

    match /watchPartyRooms/{roomId} {
      allow read: if signedIn();
      allow create:
        if signedIn()
        && request.resource.data.hostUid == request.auth.uid;
      allow update, delete:
        if signedIn()
        && resource.data.hostUid == request.auth.uid;

      match /members/{uid} {
        allow read: if signedIn();
        allow create, update, delete:
          if signedIn() && request.auth.uid == uid;
      }

      match /messages/{messageId} {
        allow read: if signedIn();
        allow create:
          if signedIn()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 280;
        allow update, delete: if false;
      }
    }

    match /contentRequests/{id} {
      allow create:
        if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow read:
        if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /brokenLinkReports/{id} {
      allow create:
        if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow read:
        if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /cineflexNotifications/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /importedContent/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /cineflexConfig/{documentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
